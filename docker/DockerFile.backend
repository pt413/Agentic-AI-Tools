# =========================================================
# Base Image
# =========================================================
FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    HF_HOME=/home/appuser/.cache/huggingface \
    PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

WORKDIR /app

# =========================================================
# System Dependencies
# =========================================================
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-dev \
    python3.11-venv \
    python3-pip \
    gcc \
    g++ \
    build-essential \
    git \
    curl \
    libpq-dev \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    poppler-utils \
    ffmpeg \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-hin \
    tesseract-ocr-osd \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# =========================================================
# Node.js (optional)
# =========================================================
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && node -v && npm -v

# =========================================================
# Python Setup
# =========================================================
RUN ln -sf /usr/bin/python3.11 /usr/bin/python && \
    python -m ensurepip --upgrade || true && \
    python -m pip install --upgrade pip setuptools wheel

# =========================================================
# Install PyTorch (GPU) - Stable CUDA 12.8
# =========================================================
RUN python -m pip install --no-cache-dir \
    torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu128
    
    
# =========================================================
# Install Python dependencies
# IMPORTANT:
# - requirement.txt should NOT contain torch / torchvision / torchaudio
# - remove regex==2025.9.1 if still present
# =========================================================
COPY requirement.txt .

RUN python -m pip install --no-cache-dir \
    --timeout 1200 \
    --retries 20 \
    -r requirement.txt

# =========================================================
# Install latest transformers from GitHub
# IMPORTANT:
# - requirement.txt should not pin transformers separately
# =========================================================
RUN python -m pip uninstall -y transformers || true && \
    python -m pip install --no-cache-dir git+https://github.com/huggingface/transformers

# =========================================================
# Quick verification before switching user
# =========================================================
RUN python -c "import sys; print(sys.executable)" && \
    python -c "import transformers; print(transformers.__version__)"

# =========================================================
# Create user
# =========================================================
RUN useradd -m -G video appuser

# =========================================================
# Prepare HuggingFace cache
# =========================================================
RUN mkdir -p /home/appuser/.cache/huggingface \
    && chown -R appuser:appuser /home/appuser/.cache

# =========================================================
# Pre-download models
# =========================================================
USER appuser

RUN python -c "from transformers import CLIPModel, CLIPProcessor; \
CLIPModel.from_pretrained('openai/clip-vit-base-patch32'); \
CLIPProcessor.from_pretrained('openai/clip-vit-base-patch32')"

RUN python -c "from sentence_transformers import SentenceTransformer; \
SentenceTransformer('all-MiniLM-L6-v2')"

RUN python -c "from transformers import AutoProcessor, Qwen2_5_VLForConditionalGeneration; \
AutoProcessor.from_pretrained('Qwen/Qwen2.5-VL-3B-Instruct', trust_remote_code=True); \
Qwen2_5_VLForConditionalGeneration.from_pretrained('Qwen/Qwen2.5-VL-3B-Instruct', trust_remote_code=True)"

# =========================================================
# Back to root
# =========================================================
USER root

# =========================================================
# Node dependencies
# =========================================================
COPY package*.json ./
RUN npm install --omit=dev || true

# =========================================================
# Copy app
# =========================================================
COPY --chown=appuser:appuser . .

# =========================================================
# Final user
# =========================================================
USER appuser

# =========================================================
# Expose
# =========================================================
EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
