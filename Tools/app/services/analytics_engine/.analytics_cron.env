# AnalyticsEngine cron env
# Store this file at:
#   /home/bpai/BP_AI/FastApi/app/services/analytics_engine/.analytics_cron.env
#
# Keep private:
#   chmod 600 /home/bpai/BP_AI/FastApi/app/services/analytics_engine/.analytics_cron.env

# -----------------------------------------------------------------------------
# App paths
# -----------------------------------------------------------------------------
APP_DIR=/home/bpai/BP_AI/FastApi
VENV_DIR=/home/bpai/BP_AI/FastApi/ocr_env
ANALYTICS_DAILY_SCRIPT=/home/bpai/BP_AI/FastApi/app/services/analytics_engine/scripts/run_daily_analytics_incremental.sh

# -----------------------------------------------------------------------------
# SSH tunnel (RMS MySQL via EC2)
# Equivalent to:
# ssh -4 -i ec2-key.pem \
#   -L 127.0.0.1:3307:database-1.clsi2m2gmodx.ap-south-1.rds.amazonaws.com:3306 \
#   ec2-user@65.1.44.87
# -----------------------------------------------------------------------------
ENABLE_SSH_TUNNEL=1
SSH_KEY_PATH=/home/bpai/.ssh/bpai-analytics/ec2-key.pem
SSH_USER=ec2-user
SSH_HOST=65.1.44.87
SSH_PORT=22

LOCAL_MYSQL_HOST=127.0.0.1
LOCAL_MYSQL_PORT=3307
REMOTE_MYSQL_HOST=database-1.clsi2m2gmodx.ap-south-1.rds.amazonaws.com
REMOTE_MYSQL_PORT=3306

# -----------------------------------------------------------------------------
# Source DBs
# -----------------------------------------------------------------------------

# RMS MySQL (through SSH tunnel)
MYSQL_DATABASE_URL=mysql+pymysql://readonly_admin:dbra%23pasS@127.0.0.1:3307/rms_db

# Recording / transcript Postgres (Neon)
# Directly reachable, so no SSH tunnel needed
ENABLE_RECORDING_PG_TUNNEL=0
THIRDPARTY_POSTGRES_URL=postgresql://bpai:bpai@127.0.0.1:6433/main?sslmode=disable

# AnalyticsEngine target DB (local postgres / docker)
DATABASE_URL=postgresql://bpai:bpai@127.0.0.1:6433/main?sslmode=disable

# -----------------------------------------------------------------------------
# Job tuning
# -----------------------------------------------------------------------------
STAGE_LIMIT=50000
STAGE_MAX_BATCHES=20
CALL_LIMIT=300000

# Optional timeout / cron metadata
ANALYTICS_DAILY_TIMEOUT_SECONDS=14400
ANALYTICS_DAILY_CRON_HOUR=2
ANALYTICS_DAILY_CRON_MINUTE=30
